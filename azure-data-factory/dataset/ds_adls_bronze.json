{
	"name": "ds_adls_bronze",
	"properties": {
		"linkedServiceName": {
			"referenceName": "ls_adls",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"table_name": {
				"type": "string"
			},
			"folder_date": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "Parquet",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@concat(dataset().table_name, '/', dataset().folder_date,'.parquet')",
					"type": "Expression"
				},
				"folderPath": {
					"value": "@split(dataset().table_name, '.')[0]",
					"type": "Expression"
				},
				"fileSystem": "bronze"
			},
			"compressionCodec": "snappy"
		},
		"schema": []
	}
}